{
  "permissions": {
    "allow": [
      "Bash(git init:*)",
      "Bash(git config:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git remote:*)",
      "Bash(git push:*)",
      "Bash(cargo search:*)",
      "Bash(cargo build:*)",
      "Bash(CARGO_REGISTRIES_CRATES_IO_PROTOCOL=sparse cargo build)",
      "Bash(cargo --version)",
      "Bash(rustc --version)",
      "Bash(rustup update:*)",
      "Bash(export RUSTUP_DIST_SERVER=\"https://rsproxy.cn\")",
      "Bash(export RUSTUP_UPDATE_ROOT=\"https://rsproxy.cn/rustup\")",
      "Bash(curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs)",
      "Bash(sh -s -- -y)",
      "Bash(source \"$HOME/.cargo/env\")",
      "Bash(cargo doc:*)",
      "Bash(git reset:*)",
      "Bash(mkdir -p ~/.ssh)",
      "Bash(ssh-keyscan github.com)",
      "Bash(~/.ssh/known_hosts)",
      "Bash(gh auth:*)",
      "Bash(git rm:*)",
      "Bash(chmod:*)",
      "Bash(./run.sh)",
      "Bash(ls -la *.sh)",
      "Bash(timeout 5 ./coding-agent/run.sh)"
    ]
  }
}
