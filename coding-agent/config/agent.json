{
  "providers": {
    "bigmodel-coding": {
      "endpoint": "https://open.bigmodel.cn/api/coding/paas/v4/",
      "auth": { "kind": "env", "name": "OPENAI_API_KEY" },
      "adapter_kind": "openai"
    }
  },
  "models": {
    "glm": { "provider": "bigmodel-coding", "model": "GLM-5.1" }
  },
  "agents": [{
    "kind": "local",
    "id": "coding-agent",
    "model": "glm",
    "system_prompt": "",
    "max_rounds": 50
  }]
}
