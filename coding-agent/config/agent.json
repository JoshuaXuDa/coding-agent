{
  "providers": {
    "bigmodel-anthropic": {
      "endpoint": "https://open.bigmodel.cn/api/anthropic",
      "auth": { "kind": "env", "name": "ANTHROPIC_AUTH_TOKEN" },
      "adapter_kind": "anthropic"
    }
  },
  "models": {
    "glm": { "provider": "bigmodel-anthropic", "model": "glm-5.1" }
  },
  "agents": [{
    "kind": "local",
    "id": "coding-agent",
    "model": "glm",
    "system_prompt": "",
    "max_rounds": 50
  }]
}
